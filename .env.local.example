# Copie ce fichier en .env.local et remplis les valeurs depuis ton projet Supabase
# (Dashboard Supabase > Project Settings > API)

# URL du projet, ex. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Clé "service_role" (secrète !) — jamais exposée au client, utilisée uniquement
# dans les API routes / server actions Next.js côté serveur.
SUPABASE_SERVICE_ROLE_KEY=

# Envoi de courriels (vérification d'adresse, digest hebdomadaire) via Resend
# (https://resend.com). Optionnel : sans ces variables, l'envoi est un no-op
# silencieux (utile en dev local sans compte Resend).
RESEND_API_KEY=
EMAIL_FROM="Rotation <rotation@ton-domaine.tld>"

# URL publique de l'app, utilisée pour construire les liens dans les courriels
# (ex. https://rotation-gules.vercel.app en production, http://localhost:3000 en dev).
APP_BASE_URL=http://localhost:3000

# Limitation du nombre de requêtes (anti-bruteforce/anti-spam) via Upstash Redis
# (https://upstash.com, offre gratuite largement suffisante). Optionnel : sans ces
# variables, la limitation est un no-op silencieux (utile en dev local).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Secret partagé pour sécuriser /api/cron/weekly-digest (Vercel envoie automatiquement
# ce header sur les tâches cron s'il connaît cette variable). Sans elle, l'endpoint
# refuse toute requête (401) — génère une valeur aléatoire longue.
CRON_SECRET=

# Intégration Discord (lien de compte OAuth2 + partage automatique via bot).
# Client ID/Secret depuis https://discord.com/developers/applications — ajoute
# ${APP_BASE_URL}/api/account/discord/callback comme redirect URI autorisée.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Même valeur que DISCORD_CLIENT_ID, exposée côté client (nécessaire pour construire
# le lien d'invitation du bot dans les réglages du groupe — un client ID n'est pas secret).
NEXT_PUBLIC_DISCORD_CLIENT_ID=
# Secret partagé entre cette app et le bot Discord (discord-bot/), pour sécuriser
# POST /api/discord/share. Génère une valeur aléatoire longue.
DISCORD_BOT_SECRET=

# Notifications push (Web Push / VAPID) — génère la paire avec :
# npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Adresse de contact requise par la spec VAPID (mailto:toi@exemple.com)
VAPID_SUBJECT=
# Même valeur que VAPID_PUBLIC_KEY, exposée côté client (nécessaire pour
# pushManager.subscribe — une clé publique VAPID n'est pas secrète).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Suggestion automatique de genre musical via l'API officielle Spotify (Client
# Credentials — aucune connexion utilisateur requise). Crée une appli sur
# https://developer.spotify.com/dashboard pour obtenir ces identifiants. Optionnel :
# sans eux, le tagging reste entièrement manuel.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
